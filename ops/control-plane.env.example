HTTP_ADDR=:8443
DATABASE_URL=postgres://astrality:astrality@127.0.0.1:5432/astrality?sslmode=disable
DATA_DIR=/var/lib/astrality
# Optional SSH jump host for console websocket proxy (example: bastion.example.internal).
BASTION_HOST=
# Backward-compatible default user (used if CONSOLE_SSH_USERS is empty).
CONSOLE_SSH_USER=root
# Ordered SSH users to try for console proxy.
CONSOLE_SSH_USERS=root,ubuntu,debian,ec2-user,centos,admin
# Ordered route targets to try: ip,hostname.
CONSOLE_TARGET_ORDER=ip,hostname
# Optional SSH private key path used by console websocket proxy.
# CONSOLE_SSH_KEY_FILE=/etc/astrality/console-proxy.key
DB_TIMEOUT_SEC=5
ENROLL_RATE_PER_MINUTE=30
LOGIN_RATE_PER_MINUTE=20
HEARTBEAT_OFFLINE_SEC=60
ALERT_EVAL_SEC=30
NOTIFY_SCAN_SEC=5
# WEBHOOK_HMAC_SECRET=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=astrality@localhost

# Production
# OIDC_ISSUER=https://sso.example.com/realms/ops
# OIDC_AUDIENCE=astrality
# OIDC_CLIENT_SECRET=
# TLS_CERT_FILE=/etc/astrality/tls/server.crt
# TLS_KEY_FILE=/etc/astrality/tls/server.key
# CLIENT_CA_FILE=/etc/astrality/tls/client-ca.pem

# Development only
# DEV_INSECURE_HTTP=true
