HTTP_ADDR=:8443
DATABASE_URL=postgres://astrality:astrality@127.0.0.1:5432/astrality?sslmode=disable
DATA_DIR=/var/lib/astrality
BASTION_HOST=bastion.internal
DB_TIMEOUT_SEC=5
ENROLL_RATE_PER_MINUTE=30
HEARTBEAT_OFFLINE_SEC=60
ALERT_EVAL_SEC=30
NOTIFY_SCAN_SEC=5
# WEBHOOK_HMAC_SECRET=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=astrality@localhost

# Production
# OIDC_ISSUER=https://sso.example.com/realms/ops
# OIDC_AUDIENCE=astrality
# TLS_CERT_FILE=/etc/astrality/tls/server.crt
# TLS_KEY_FILE=/etc/astrality/tls/server.key
# CLIENT_CA_FILE=/etc/astrality/tls/client-ca.pem

# Development only
# DEV_INSECURE_HTTP=true
