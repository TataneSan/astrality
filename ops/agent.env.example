SERVER_URL=https://control-plane.example.com:8443
ENROLL_TOKEN=
DATA_DIR=/etc/astrality
AGENT_VERSION=0.1.0
HEARTBEAT_SEC=15
FACTS_SEC=300
JOB_POLL_SEC=5
JOB_ALLOWLIST=uname,uptime,df,free,echo,cat,ls,systemctl,journalctl
INSECURE_ENROLL_TLS=false
INSECURE_HTTP=false
AGENT_ENV_FILE=/etc/astrality/agent.env
