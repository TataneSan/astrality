[Unit]
Description=astrality agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
EnvironmentFile=-/etc/astrality/agent.env
Environment=AGENT_ENV_FILE=/etc/astrality/agent.env
ExecStart=/usr/local/bin/astrality-agent
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
